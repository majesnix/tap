{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Proto Sender",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-write-text-file",
    { "identifier": "fs:scope", "allow": [{ "path": "$HOME/**" }] },
    "store:default",
    "store:allow-load",
    "store:allow-set",
    "store:allow-save",
    "store:allow-get"
  ]
}
