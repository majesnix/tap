{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tap",
  "version": "1.5.0",
  "identifier": "com.tap.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tap",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "untrusted comment: minisign public key: 47DE72BD11907EBC\nRWS8fpARvXLeR6x4Bbx5fhhzIGQSZoQWH/6nCWBfXmF40CEiR56FP6Dy\n",
      "endpoints": [
        "https://github.com/majesnix/tap/releases/latest/download/latest.json"
      ]
    }
  }
}
